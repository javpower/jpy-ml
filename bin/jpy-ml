#!/bin/bash
# jpy-ml CLI launcher (Linux/macOS/Windows Git Bash)
set -e

DIR="$(cd "$(dirname "$0")" && pwd)"
JAR="$DIR/lib/jpy-ml-cli.jar"

if [ ! -f "$JAR" ]; then
    echo "Error: $JAR not found" >&2
    echo "Build with: mvn package -Pcli -DskipTests" >&2
    exit 1
fi

# 检测打包的 JRE (兼容 Windows Git Bash)
JRE="$DIR/../jre/bin/java"
JRE_EXE="$DIR/../jre/bin/java.exe"

if [ -f "$JRE" ]; then
    exec "$JRE" -jar "$JAR" "$@"
elif [ -f "$JRE_EXE" ]; then
    exec "$JRE_EXE" -jar "$JAR" "$@"
fi

# 否则使用系统的 java
if command -v java &> /dev/null; then
    exec java -jar "$JAR" "$@"
fi

echo "Error: Java not found" >&2
echo "Install JDK 17 or use the bundled package" >&2
exit 1
